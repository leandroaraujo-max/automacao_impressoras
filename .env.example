# .env.example — Modelo de configuração (versionar este arquivo)
# Copie para .env e preencha com seus valores reais.
# O arquivo .env nunca deve ser comitado (ver .gitignore).

# Porta do servidor Flask
PROBE_PORT=8080

# Comunidade SNMP (leitura)
SNMP_COMMUNITY=public

# Timeouts em segundos
HTTP_TIMEOUT=3
SNMP_TIMEOUT=2

# Número máximo de scans nmap paralelos
MAX_CONCURRENT=10

# Credenciais HP EWS (usuários e senhas separados por vírgula)
HP_EWS_USERS=administrador,admin
HP_EWS_PASSWORDS=SENHA1,SENHA2,

# Credenciais Samsung SyncThru
SAMSUNG_USER=admin
SAMSUNG_PASSWORDS=SENHA1,SENHA2,

# Credenciais Zebra ZebraNet
ZEBRA_USER=admin
ZEBRA_PASSWORDS=SENHA1,SENHA2,

# ---------------------------------------------------------------------------
# Autenticação LDAP / Active Directory (opcional)
# DCs descobertos automaticamente via DNS SRV — não é necessário listar IPs.
# Defina AD_DOMAIN para ativar. Deixe em branco para usar só o admin.key.
# ---------------------------------------------------------------------------

# Domínio AD — DCs resolvidos via _ldap._tcp.dc._msdcs.<AD_DOMAIN>
AD_DOMAIN=magazineluiza.intranet

# Base DN para pesquisa de grupo (derivada do domínio)
AD_BASE_DN=DC=magazineluiza,DC=intranet

# DN do grupo de administradores de impressoras
# (opcional — se vazio, qualquer login válido no AD é aceito como admin)
AD_ADMIN_GROUP=

# Usar LDAPS / SSL (true/false) — false usa LDAP porta 389
AD_USE_SSL=false

# Timeout de conexão LDAP em segundos
AD_TIMEOUT=5
